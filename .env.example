# Copy → .env.local. SCOPES must match shopify.app.toml + Partners.

# Production (Vercel) — no trailing slash for OAuth base (code strips it):
# SHOPIFY_APP_URL=https://cart-raise.vercel.app
# NEXT_PUBLIC_APP_URL=https://cart-raise.vercel.app

# Local:
SHOPIFY_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# CartRaise — Private embedded app (SHOPIFY_API_KEY must match client_id in shopify.app.toml)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products,read_orders

DEBUG_OAUTH=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Partners: Distribution = Private, App URL https://cart-raise.vercel.app/
# Redirect: https://cart-raise.vercel.app/api/shopify/callback
# Deploy config: shopify app deploy
