# --- Shopify (Custom app / Partners) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://cart-raise.vercel.app
SCOPES=read_products,write_cart

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Required on the server to upsert shop + access_token after OAuth (keep secret; never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional legacy / local fallback if SHOPIFY_APP_URL unset (Vercel sets VERCEL_URL automatically)
# NEXT_PUBLIC_APP_URL=https://cart-raise.vercel.app

# --- Test on Vercel ---
# 1) Vercel → Project → Settings → Environment Variables: copy all keys above for Production (and Preview if needed).
# 2) Shopify Partners → your app → Configuration:
#    - App URL: https://cart-raise.vercel.app (or your Vercel URL)
#    - Allowed redirection URL(s): https://cart-raise.vercel.app/api/shopify/callback
# 3) Open: https://cart-raise.vercel.app/api/shopify/auth?shop=YOUR-STORE.myshopify.com
# 4) Complete install → expect redirect to /dashboard?shop=YOUR-STORE.myshopify.com
# 5) Supabase: run supabase/schema.sql so table `shops` exists.
