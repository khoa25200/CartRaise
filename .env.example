# Copy → .env.local and fill values.
# SCOPES must match Partners + shopify.app.toml [access_scopes].scopes

# --- Public app URL (no trailing slash) ---
# Local:
SHOPIFY_APP_URL=http://localhost:3000
# Optional alias (same value as SHOPIFY_APP_URL if both set):
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (Vercel): https://your-project.vercel.app
# On Vercel, VERCEL_URL is set automatically if SHOPIFY_APP_URL is empty (not ideal for OAuth redirect_uri — prefer explicit SHOPIFY_APP_URL).

# --- Shopify Custom app ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products,read_orders
# Optional fallback name (same as SCOPES):
# SHOPIFY_SCOPES=read_products,write_products,read_orders

# --- Supabase (server routes use service role only today) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: only if you call getSupabaseAnon() later ---
# SUPABASE_ANON_KEY=

# --- Checklist ---
# 1) Supabase SQL Editor: run supabase/schema.sql
# 2) Partners: App URL = SHOPIFY_APP_URL, Redirect = {SHOPIFY_APP_URL}/api/shopify/callback
# 3) shopify.app.toml: client_id = SHOPIFY_API_KEY; URLs match this app
# 4) Webhooks resolve to {SHOPIFY_APP_URL}/api/webhooks/shopify
# 5) Local: GET http://localhost:3000/api/shopify/auth → {"ok":true}
# 6) Install: /api/shopify/auth?shop=your-store.myshopify.com → /dashboard?shop=...
